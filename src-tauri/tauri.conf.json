{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "RetroDev Studio",
  "version": "0.1.0",
  "identifier": "com.retrodevstudio.desktop",
  "build": {
    "beforeDevCommand": "cmd /c npm run dev",
    "beforeBuildCommand": "cmd /c npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RetroDev Studio",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$TEMP/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "publisher": "RetroDev Team",
    "shortDescription": "RetroDev Studio desktop toolkit for 16-bit console development.",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US",
        "upgradeCode": "3f9f8354-4db5-5f1d-8c87-7af1c2c3984a"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://updates.retrodevstudio.example.invalid/{{target}}/{{current_version}}"
      ],
      "pubkey": "PLACEHOLDER_UPDATER_PUBKEY_BLOCKED_BY_NO_NEW_DEPS"
    }
  }
}
