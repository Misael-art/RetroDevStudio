{
  "name": "retrodev-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:debug": "node scripts/build.mjs debug",
    "build:debug:open": "node scripts/build.mjs debug --open-dir",
    "build:msi": "node scripts/build.mjs msi",
    "build:msi:open": "node scripts/build.mjs msi --open-dir",
    "build:portable": "node scripts/build.mjs portable",
    "build:portable:open": "node scripts/build.mjs portable --open-dir",
    "build:all": "node scripts/build.mjs all",
    "release:readiness": "node scripts/release-readiness.mjs",
    "release:readiness:baseline": "node scripts/release-readiness.mjs --run-baseline",
    "lint": "eslint src vite.config.ts --max-warnings=0",
    "preview": "vite preview",
    "check:tree": "node scripts/check-tree.cjs",
    "test": "vitest run",
    "test:e2e:desktop": "node scripts/e2e-tauri-build-run.mjs",
    "test:e2e:desktop:md": "node scripts/e2e-tauri-build-run.mjs --project src-tauri/tests/fixtures/projects/megadrive_dummy",
    "test:e2e:desktop:snes": "node scripts/e2e-tauri-build-run.mjs --project src-tauri/tests/fixtures/projects/snes_dummy",
    "test:e2e:desktop:live-overflow": "node scripts/e2e-tauri-build-run.mjs --scenario live-overflow --project src-tauri/tests/fixtures/projects/megadrive_dummy",
    "test:e2e:desktop:live-overflow:md": "node scripts/e2e-tauri-build-run.mjs --scenario live-overflow --project src-tauri/tests/fixtures/projects/megadrive_dummy",
    "test:e2e:desktop:live-overflow:snes": "node scripts/e2e-tauri-build-run.mjs --scenario live-overflow --project src-tauri/tests/fixtures/projects/snes_dummy",
    "test:e2e:desktop:live-overflow-vram:md": "node scripts/e2e-tauri-build-run.mjs --scenario live-overflow-vram --project src-tauri/tests/fixtures/projects/megadrive_dummy",
    "test:e2e:desktop:live-overflow-vram:snes": "node scripts/e2e-tauri-build-run.mjs --scenario live-overflow-vram --project src-tauri/tests/fixtures/projects/snes_dummy",
    "test:e2e:desktop:live-warning-vram:md": "node scripts/e2e-tauri-build-run.mjs --scenario live-warning-vram --project src-tauri/tests/fixtures/projects/megadrive_dummy",
    "test:e2e:desktop:live-warning-vram:snes": "node scripts/e2e-tauri-build-run.mjs --scenario live-warning-vram --project src-tauri/tests/fixtures/projects/snes_dummy",
    "test:e2e:desktop:live-warning-sprites:md": "node scripts/e2e-tauri-build-run.mjs --scenario live-warning-sprites --project src-tauri/tests/fixtures/projects/megadrive_dummy",
    "test:e2e:desktop:live-warning-sprites:snes": "node scripts/e2e-tauri-build-run.mjs --scenario live-warning-sprites --project src-tauri/tests/fixtures/projects/snes_dummy",
    "test:e2e:desktop:live-ok:md": "node scripts/e2e-tauri-build-run.mjs --scenario live-ok --project src-tauri/tests/fixtures/projects/megadrive_dummy",
    "test:e2e:desktop:live-ok:snes": "node scripts/e2e-tauri-build-run.mjs --scenario live-ok --project src-tauri/tests/fixtures/projects/snes_dummy",
    "test:e2e:desktop:live-error:md": "node scripts/e2e-tauri-build-run.mjs --scenario live-error --project src-tauri/tests/fixtures/projects/megadrive_dummy",
    "test:e2e:desktop:live-error:snes": "node scripts/e2e-tauri-build-run.mjs --scenario live-error --project src-tauri/tests/fixtures/projects/snes_dummy",
    "test:e2e:desktop:live-stale:md": "node scripts/e2e-tauri-build-run.mjs --scenario live-stale --project src-tauri/tests/fixtures/projects/megadrive_dummy",
    "test:e2e:desktop:live-stale:snes": "node scripts/e2e-tauri-build-run.mjs --scenario live-stale --project src-tauri/tests/fixtures/projects/snes_dummy",
    "test:e2e:desktop:build-blocked-diagnostic": "node scripts/e2e-tauri-build-run.mjs --scenario build-blocked-diagnostic --project src-tauri/tests/fixtures/projects/megadrive_dummy",
    "test:e2e:desktop:onboarding-shell": "node scripts/e2e-tauri-build-run.mjs --scenario onboarding-shell",
    "test:e2e:desktop:qa-rc": "node scripts/e2e-tauri-build-run.mjs --scenario qa-rc",
    "preflight:sgdk-e2e": "node scripts/sgdk-e2e-host-preflight.mjs",
    "test:watch": "vitest",
    "release:readiness:promotion": "node scripts/release-readiness.mjs --run-baseline --manual-qa-json src-tauri/target-test/validation/manual-qa-status.json --strict",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "react": "^19",
    "react-dom": "^19",
    "react-resizable-panels": "^4.7.3",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "@vitest/browser": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.6",
    "typescript-eslint": "^8.58.0",
    "vite": "^6",
    "vitest": "^4.0.18"
  }
}
