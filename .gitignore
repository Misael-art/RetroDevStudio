# ==============================================================================
# RetroDev Studio - .gitignore
# ==============================================================================

# --- Node / Frontend ---
node_modules/
dist/
*.local
tsconfig.tsbuildinfo
*.tsbuildinfo

# --- Rust / Backend ---
target/
src-tauri/target-test/
src-tauri/target-sprint*/
whitelist_target/
Cargo.lock
*.pdb
*.ilk
*.idb

# --- Tauri ---
WixTools/
*.msi
*.nsis
*.deb
*.rpm
*.AppImage
*.app/
*.exe

# --- Toolchains (binarios pesados, baixar separadamente) ---
toolchains/sgdk/
toolchains/pvsneslib/
toolchains/jdk/
toolchains/env/
toolchains/webdriver/
toolchains/libretro/cores/
toolchains/libretro/.retrodev-install-*.json
!toolchains/sgdk/.gitkeep
!toolchains/pvsneslib/.gitkeep

# --- Build artifacts ---
build/
*.rom
*.md.bin
*.sfc
*.smc

# --- IDE ---
.vscode/
.cursor/
.claude/settings.local.json
.claude/worktrees/
.claude/workspaces/
.claude/scheduled_tasks.lock
.idea/
*.swp
*.swo

# --- OS ---
Thumbs.db
.DS_Store
Desktop.ini

# --- Logs ---
*.log
bootstrap.log

# --- Environment ---
.env
.env.local

# --- Temp scripts ---
scripts/setup-rust.ps1
scripts/run-bootstrap.ps1

# --- Tauri signing (private key must never be committed) ---
scripts/_tauri_signing
scripts/_tauri_signing.pub

# --- Local diagnostics ---
vitest-err.txt
vitest-output.txt
